<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans
         http://www.springframework.org/schema/beans/spring-beans.xsd
         http://www.springframework.org/schema/context
         http://www.springframework.org/schema/context/spring-context.xsd">

    <!-- Enables @Autowired, @Qualifier, etc. -->
    <context:annotation-config/>

<bean id="address1" class="com.model.Address">
<property name="city" value="pune"></property>
<property name="state" value="Maharashtra"></property>
</bean>

<bean id="address2" class="com.model.Address">
<property name="city" value="thane"></property>
<property name="state" value="Maharashtra"></property>
</bean>

<bean id="s" class="com.model.Student">
<property name="id" value="101"></property>
<property name="name" value="ramesh"></property>
</bean>

</beans>