<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="s" class="com.model.Student">
		<constructor-arg name="marks">
			<list>
				<value>98</value>
				<value>99</value>
				<value>100</value>
			</list>
		</constructor-arg>

		<constructor-arg name="name">
			<set>
				<value>aman</value>
				<value>suman</value>
				<value>pawan</value>
			</set>
		</constructor-arg>

		<constructor-arg name="idName">
			<map>
				<entry key="101" value="rahul"></entry>
				<entry key="102" value="sagar"></entry>
				<entry key="103" value="pooja"></entry>
			</map>
		</constructor-arg>

	</bean>


</beans>