<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="s" class="com.model.Student">
		<property name="marks">
			<list>
				<value>70</value>
				<value>56</value>
				<value>80</value>
			</list>
		</property>

		<property name="name">
			<set>
				<value>Ramesh</value>
				<value>rakesh</value>
				<value>Ravi</value>
			</set>
		</property>

		<property name="idName">
			<map>
				<entry key="101" value="ram"></entry>
				<entry key="102" value="suman"></entry>
				<entry key="103" value="shyam"></entry>
			</map>
		</property>
	</bean>


</beans>