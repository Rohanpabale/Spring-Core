<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

<bean id="a" class="com.model.Address">
<constructor-arg name="city" value="thane"></constructor-arg>
<constructor-arg name="state" value="Maharashtra"></constructor-arg>
</bean>

<bean id="s" class="com.model.Student">
<constructor-arg name="id" value="101"></constructor-arg>
<constructor-arg name="name" value="rohit"></constructor-arg>
<constructor-arg name="address" ref="a"></constructor-arg>
</bean>


</beans>