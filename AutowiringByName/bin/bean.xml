<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="address" class="com.model.Address">
	<property name="city" value="patna"></property>
	<property name="state" value="bihar"></property>
	</bean>
	
	<bean id="s" class="com.model.Student" autowire="byName">
	<property name="id" value="101"></property>
	<property name="name" value="babubhaiya"></property>
	</bean>

	

</beans>